   "source": [
    "from runners import run_mesh, run_mesh_old, run_nsga2\n",
    "\n",
    "from functools import partial\n",
    "from joblib import Parallel, delayed\n",
    "\n",
    "import contextlib\n",
    "import io\n",
    "\n",
    "# Adds the parent directory to sys.path\n",
    "import sys\n",
    "sys.path.append('../')\n",
    "from problems.problems import get_problem"
   ]
